# Copy to .env and fill in values. Never commit .env (see .gitignore).

# --- Required (Vite / Supabase browser client) ---
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_publishable_key_here

# Optional: if VITE_SUPABASE_URL is omitted, some code paths can build URL from project id
# VITE_SUPABASE_PROJECT_ID=YOUR_PROJECT_REF

# --- Optional site / SEO ---
# VITE_SITE_URL=https://your-production-domain.com

# --- Optional feature flags (build-time; see src/lib/featureFlags.ts) ---
# VITE_FEATURE_NFC_CATALOG=true
# VITE_FEATURE_DIGITAL_CARD=true
