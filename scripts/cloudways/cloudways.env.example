# Copy to .env in this folder (see .gitignore). Do not commit secrets.

CLOUDWAYS_HOST=your.server.ip
CLOUDWAYS_SSH_PORT=22
CLOUDWAYS_USER=master_xxxxx

# Password SSH (recommended for Cloudways when you use panel password)
CLOUDWAYS_SSH_PASSWORD=

# Optional: private key path instead of password (then rsync+ssh is used)
# CLOUDWAYS_SSH_KEY=

CLOUDWAYS_REMOTE_DIR=/home/master/applications/APP_NAME/public_html/diamony

# After build, copy dist/ to the parent public_html/ and disable default index.php
# (Vite assets use absolute / paths). Use this when CLOUDWAYS_REMOTE_DIR is .../public_html/<subdir>.
# CLOUDWAYS_PUBLISH_TO_WEB_ROOT=1

# CLOUDWAYS_LOCAL_ROOT=/path/to/diamony
# CLOUDWAYS_SKIP_RSYNC=0

# Note: Cloudways often returns HTTP 403 for bare server IP. Use the application URL from
# applications/<APP_ID>/conf/server.nginx (e.g. *.cloudwaysapps.com) until you attach a domain.

# --- Vite (inlined at `npm run build`; exported automatically by deploy.py) ---
# VITE_SUPABASE_URL=
# VITE_SUPABASE_PUBLISHABLE_KEY=
# VITE_BRAND_ID=b0000000-0000-4000-8000-000000000001
# VITE_SITE_URL=
# VITE_FEATURE_NFC_CATALOG=true
# VITE_FEATURE_DIGITAL_CARD=true
